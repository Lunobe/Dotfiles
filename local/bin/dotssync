#!/bin/bash
if [ -z "$1" ]; then
    echo "Ошибка: укажи описание коммита."
    exit 1
fi

# Обновляем список пакетов
yay -Qeq > ~/Dotfiles/packages.txt

cd ~/Dotfiles || exit

# Показываем, что изменилось, но БЕЗ игнорируемых файлов
echo "--- Текущие изменения ---"
git status --short

# Спрашиваем подтверждение, если есть новые файлы
# (Чтобы случайно не запушить то, что забыл внести в .gitignore)
read -p "Пушим? (y/n): " confirm
if [[ $confirm == [yY] ]]; then
    git add -A
    git commit -m "$1"
    git push -u origin main
    echo "✅ Улетело в облако!"
else
    echo "❌ Отмена. Проверь файлы."
fi
