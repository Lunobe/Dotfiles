#!/bin/bash
if [ -z "$1" ]; then
    echo "Error: provide a commit message."
    exit 1
fi

# Update package list
yay -Qeq > ~/Dotfiles/packages.txt

cd ~/Dotfiles || exit

# Show what changed, but WITHOUT ignored files
echo "--- Current changes ---"
git status --short

# Ask for confirmation if there are new files
# (To avoid accidentally pushing something not in .gitignore)
read -p "Push? (y/n): " confirm
if [[ $confirm == [yY] ]]; then
    git add -A
    git commit -m "$1"
    git push -u origin main
    echo "✅ Pushed to the cloud!"
else
    echo "❌ Cancelled. Check the files."
fi
