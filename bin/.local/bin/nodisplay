#!/bin/bash

set -euo pipefail

SEARCH_DIRS=(
    "/usr/share/applications"
    "/usr/local/share/applications"
    "$HOME/.local/share/applications"
    "/var/lib/snapd/desktop/applications"
    "/var/lib/flatpak/exports/share/applications"
    "$HOME/.local/share/flatpak/exports/share/applications"
)

usage() {
    echo "Usage: nodisplay <program_name>" >&2
    echo "Hides the specified program from app launchers by setting NoDisplay=true" >&2
    exit 1
}

[[ $# -eq 0 ]] && usage

PROGRAM="$1"

find_desktop_files() {
    local name="${1,,}"
    for dir in "${SEARCH_DIRS[@]}"; do
        [[ -d "$dir" ]] || continue
        while IFS= read -r file; do
            local base
            base=$(basename "$file" .desktop)
            if [[ "${base,,}" == *"${name}"* ]] || grep -qi "^Name=.*${name}" "$file" 2>/dev/null; then
                echo "$file"
            fi
        done < <(find "$dir" -maxdepth 1 -name "*.desktop" 2>/dev/null)
    done
}

add_nodisplay() {
    local file="$1"

    # If not writable, copy to user applications dir
    if [[ ! -w "$file" ]]; then
        local user_dir="$HOME/.local/share/applications"
        mkdir -p "$user_dir"
        local dest="$user_dir/$(basename "$file")"
        cp "$file" "$dest"
        echo "  Copied to user dir: $dest"
        file="$dest"
    fi

    local tmpfile
    tmpfile=$(mktemp)

    # Add/replace NoDisplay=true only inside [Desktop Entry] block
    awk '
        BEGIN { in_entry = 0; added = 0 }

        /^\[Desktop Entry\]/ {
            in_entry = 1
            print
            next
        }

        /^\[/ {
            if (in_entry && !added) {
                print "NoDisplay=true"
                added = 1
            }
            in_entry = 0
            print
            next
        }

        in_entry && /^NoDisplay=/ {
            print "NoDisplay=true"
            added = 1
            next
        }

        { print }

        END {
            if (in_entry && !added) {
                print "NoDisplay=true"
            }
        }
    ' "$file" > "$tmpfile"

    mv "$tmpfile" "$file"
    echo "  Done: $file"
}

mapfile -t FILES < <(find_desktop_files "$PROGRAM" | sort -u)

if [[ ${#FILES[@]} -eq 0 ]]; then
    echo "No .desktop files found for: '$PROGRAM'" >&2
    exit 1
fi

if [[ ${#FILES[@]} -gt 1 ]]; then
    echo "Multiple matches found:"
    for i in "${!FILES[@]}"; do
        echo "  [$i] ${FILES[$i]}"
    done
    printf "Select [0-%d] or 'a' for all: " "$((${#FILES[@]} - 1))"
    read -r choice
    case "$choice" in
        a|A)
            for file in "${FILES[@]}"; do
                add_nodisplay "$file"
            done
            ;;
        ''|*[!0-9]*)
            echo "Invalid selection" >&2; exit 1 ;;
        *)
            if [[ "$choice" -lt ${#FILES[@]} ]]; then
                add_nodisplay "${FILES[$choice]}"
            else
                echo "Invalid selection" >&2; exit 1
            fi
            ;;
    esac
else
    add_nodisplay "${FILES[0]}"
fi
